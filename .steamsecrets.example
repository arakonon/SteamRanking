# Nach ~/.steamsecrets kopieren und ausfuellen.
STEAM_API_KEY=your_steam_api_key_here
SNAPSHOT_TOKEN=your_random_token_for_webhook_auth

# Optional: Instagram-Auto-Post (falls ungenutzt, leer lassen)
INSTAGRAM_USER=
INSTAGRAM_PASS=
INSTAGRAM_SESSION_FILE=~/.secrets/instagram_session.json

# Optional: abweichender DB-Pfad
# DB_PATH=/absolute/path/to/steam_leaderboard.db
